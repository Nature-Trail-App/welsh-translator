{
  "name": "@naturetrail/welsh-translator",
  "version": "0.5.0",
  "description": "Framework-agnostic Welsh word translation with mutation normalisation, plus optional Svelte 5 components",
  "license": "GPL-3.0",
  "type": "module",
  "main": "./dist/index.js",
  "keywords": [
    "welsh",
    "cymraeg",
    "translation",
    "mutations",
    "nlp",
    "svelte",
    "language",
    "linguistics"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nature-Trail-App/welsh-translator.git"
  },
  "homepage": "https://github.com/Nature-Trail-App/welsh-translator#readme",
  "bugs": {
    "url": "https://github.com/Nature-Trail-App/welsh-translator/issues"
  },
  "scripts": {
    "dev": "vite dev",
    "demo": "vite",
    "build": "svelte-package -i src -o dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "exports": {
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "svelte": "./dist/svelte/index.js",
      "import": "./dist/svelte/index.js"
    },
    "./styles": {
      "import": "./dist/svelte/welsh-translator.css"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "bits-ui": ">=2.0.0",
    "svelte": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": true
    },
    "bits-ui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "bits-ui": "^2.15.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
